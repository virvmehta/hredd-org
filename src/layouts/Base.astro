---
import '../styles/tokens.css';
import { DEFAULT_VOL } from '../lib/volIssue.js';

interface Props {
  title?: string;
  description?: string;
  vol?: string;
  ogType?: string;
}

const {
  title = 'hredd.org',
  description = 'Independent coverage of human-rights and environmental due-diligence legislation, written from a Global South perspective.',
  vol = DEFAULT_VOL,
  ogType = 'website',
} = Astro.props;

const path = Astro.url.pathname;
const pageTitle = title === 'hredd.org' ? 'hredd.org' : `${title} | hredd.org`;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="hredd.org" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Inter:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>

<div class="topstrip">
  <div class="vol">{vol}</div>
  <div class="topstrip-right">
    <a href="/archive/">Archive</a>
    <a href="/about/#contact">Contact</a>
    <a href="/rss.xml">RSS</a>
  </div>
</div>

<nav class="nav">
  <div class="nav-left">
    <a href="/" class={path === '/' ? 'active' : ''}>Home</a>
    <a href="/tracker/" class={(path.startsWith('/tracker') || path.startsWith('/laws')) ? 'active' : ''}>Tracker</a>
  </div>
  <div class="nav-center">
    <a href="/" class="wordmark"><span class="serif">hredd<span class="glyph">·</span>org</span></a>
  </div>
  <div class="nav-right">
    <a href="/buyer-mapping/" class={path.startsWith('/buyer-mapping') ? 'active' : ''}>Buyer Mapping</a>
    <a href="/articles/" class={path.startsWith('/articles') ? 'active' : ''}>Articles</a>
    <a href="/about/" class={path.startsWith('/about') ? 'active' : ''}>About</a>
    <a href="/subscribe/" class={`subscribe-link${path.startsWith('/subscribe') ? ' active' : ''}`}>Subscribe</a>
  </div>
</nav>

<slot />

<footer class="site-footer">
  <div class="footer-inner page">
    <div class="footer-col footer-col--wide">
      <a href="/" class="serif footer-wordmark">hredd<span class="glyph">·</span>org</a>
      <p>Independent coverage of HREDD legislation, written from a Global South perspective.</p>
    </div>
    <div class="footer-col">
      <div class="footer-label">The publication</div>
      <a href="/about/">About</a>
      <a href="/about/#methodology">Methodology</a>
      <a href="/about/#funding">Funding</a>
      <a href="/subscribe/">Newsletter</a>
    </div>
    <div class="footer-col">
      <div class="footer-label">The tracker</div>
      <a href="/tracker/">All statutes</a>
      <a href="/buyer-mapping/">Buyer mapping</a>
      <a href="/articles/">Articles</a>
    </div>
    <div class="footer-col">
      <div class="footer-label">Connect</div>
      <a href="mailto:contact@hredd.org">contact@hredd.org</a>
      <a href="/rss.xml">RSS feed</a>
      <a href="/archive/">Archive</a>
    </div>
  </div>
  <div class="footer-sub page">
    <span>© 2026 HREDD · Built with care from Noida, India · contact@hredd.org</span>
  </div>
</footer>

</body>
</html>

<style>
.topstrip {
  border-bottom: 1px solid var(--rule);
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 var(--pad-x);
  height: 36px;
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-3);
}
.topstrip-right { display: flex; gap: 24px; }
.topstrip a:hover, .topstrip-right a:hover { color: var(--ink); }

.nav {
  border-bottom: 1px solid var(--rule);
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  padding: 0 var(--pad-x);
  height: 56px;
  position: sticky;
  top: 0;
  background: var(--bg);
  z-index: 100;
}
.nav-left {
  display: flex;
  gap: 28px;
  align-items: center;
  font-family: var(--sans);
  font-size: 13px;
}
.nav-right {
  display: flex;
  gap: 28px;
  align-items: center;
  justify-content: flex-end;
  font-family: var(--sans);
  font-size: 13px;
}
.nav-center { text-align: center; }
.wordmark .serif {
  font-family: var(--serif);
  font-size: 22px;
  letter-spacing: -0.01em;
}
.glyph { color: var(--accent); }
.nav a { color: var(--ink-2); }
.nav a:hover, .nav a.active { color: var(--ink); }
.subscribe-link {
  border: 1px solid var(--accent);
  padding: 4px 14px;
  color: var(--accent) !important;
}
.subscribe-link:hover { background: var(--accent); color: var(--bg) !important; }

.site-footer { border-top: 1px solid var(--rule); margin-top: 80px; }
.footer-inner {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 48px;
  padding-top: 48px;
  padding-bottom: 40px;
}
.footer-wordmark {
  display: block;
  font-family: var(--serif);
  font-size: 20px;
  margin-bottom: 12px;
  color: var(--ink);
}
.footer-col p {
  font-size: 13px;
  color: var(--ink-3);
  line-height: 1.65;
  margin: 0;
}
.footer-col a {
  display: block;
  font-family: var(--sans);
  font-size: 13px;
  color: var(--ink-3);
  margin-bottom: 8px;
}
.footer-col a:hover { color: var(--ink); }
.footer-label {
  font-family: var(--sans);
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink-3);
  margin-bottom: 16px;
}
.footer-sub {
  border-top: 1px solid var(--rule-soft);
  display: flex;
  justify-content: space-between;
  padding-top: 16px;
  padding-bottom: 24px;
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.08em;
  color: var(--ink-3);
}

@media (max-width: 900px) {
  .topstrip, .nav { padding: 0 var(--pad-x-narrow); }
  .footer-inner { grid-template-columns: 1fr 1fr; gap: 32px; padding-left: var(--pad-x-narrow); padding-right: var(--pad-x-narrow); }
  .footer-sub { padding-left: var(--pad-x-narrow); padding-right: var(--pad-x-narrow); }
  .nav { display: flex; justify-content: space-between; }
  .nav-center { display: none; }
  .nav-right { gap: 16px; }
  .nav-left { gap: 16px; }
}
</style>
