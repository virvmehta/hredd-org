---
import '../styles/global.css';

interface Props {
  title?: string;
  activePage?: string;
}

const { title = 'hredd.org', activePage = '' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>

    <!-- NAV -->
    <nav class="site-nav">
      <div class="nav-inner">
        <div class="nav-left">
          <a href="/" class="nav-wordmark">hredd.org</a>
          <span class="nav-tagline">A Global South perspective</span>
        </div>
        <div class="nav-right">
          <div class="nav-links">
            <a href="/tracker" class={`nav-link${activePage === 'tracker' ? ' nav-link--active' : ''}`}>Tracker</a>
            <a href="/articles" class={`nav-link${activePage === 'articles' ? ' nav-link--active' : ''}`}>Articles</a>
            <a href="/about" class={`nav-link${activePage === 'about' ? ' nav-link--active' : ''}`}>About</a>
            <a href="/#subscribe" class={`nav-link${activePage === 'subscribe' ? ' nav-link--active' : ''}`}>Subscribe</a>
          </div>
          <span class="nav-issue">Vol. I &middot; Issue 01 &middot; June 2026</span>
        </div>
      </div>
      <div class="nav-rule"></div>
    </nav>

    <!-- PAGE CONTENT -->
    <main>
      <slot />
    </main>

    <!-- FOOTER -->
    <footer class="site-footer">
      <div class="footer-main">
        <div class="footer-brand">
          <span class="footer-wordmark">hredd.org</span>
          <p class="footer-tagline">A Global South perspective on human rights due diligence.</p>
        </div>
        <div class="footer-cols">
          <div class="footer-col">
            <span class="footer-col-label">Resources</span>
            <ul class="footer-col-links">
              <li><a href="/tracker">Tracker</a></li>
              <li><a href="/articles">Articles</a></li>
              <li><a href="/articles">Plain-language explainers</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <span class="footer-col-label">About</span>
            <ul class="footer-col-links">
              <li><a href="/about">Mission</a></li>
              <li><a href="mailto:contact@hredd.org">Contact</a></li>
            </ul>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <span>&copy; 2026 hredd.org &middot; Independent and reader-supported</span>
        <span>Built with care from Noida, India</span>
      </div>
    </footer>

  </body>
</html>

<style>
  /* ====================================================
     NAV
     ==================================================== */

  .site-nav {
    padding: 20px 56px 0;
  }

  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding-bottom: 20px;
  }

  .nav-left {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .nav-wordmark {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: var(--text-24);
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .nav-tagline {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-13);
    color: var(--text-muted);
  }

  .nav-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
  }

  .nav-links {
    display: flex;
    gap: 28px;
    align-items: center;
  }

  .nav-link {
    font-family: var(--font-sans);
    font-size: var(--text-12);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text);
    padding-bottom: 2px;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
  }

  .nav-link:hover,
  .nav-link--active {
    border-bottom-color: var(--accent);
  }

  .nav-issue {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-13);
    color: var(--text-muted);
  }

  .nav-rule {
    height: 1px;
    background: var(--text);
    margin: 0 0px;
  }

  /* ====================================================
     FOOTER
     ==================================================== */

  .site-footer {
    border-top: 1px solid var(--text);
    margin-top: 80px;
  }

  .footer-main {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 48px 56px 40px;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-wordmark {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: var(--text-22);
    color: var(--text);
  }

  .footer-tagline {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-13);
    color: var(--text-muted);
    max-width: 240px;
    line-height: 1.5;
  }

  .footer-cols {
    display: flex;
    gap: 48px;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-col-label {
    font-family: var(--font-sans);
    font-size: var(--text-10);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
  }

  .footer-col-links {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .footer-col-links li a {
    font-family: var(--font-sans);
    font-size: var(--text-13);
    color: var(--text-mid);
    transition: color 0.15s;
  }

  .footer-col-links li a:hover {
    color: var(--accent);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 56px 40px;
    border-top: 1px solid var(--rule);
    font-family: var(--font-sans);
    font-size: var(--text-11);
    color: var(--text-muted);
  }
</style>
