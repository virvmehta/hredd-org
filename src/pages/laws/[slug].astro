---
import BaseLayout from '../../layouts/Base.astro';
import { client } from '../../lib/sanity.js';
import { LAW_BY_SLUG_QUERY, LAWS_QUERY } from '../../lib/queries.js';
import { STATIC_LAWS } from '../../lib/staticData.js';

export async function getStaticPaths() {
  let laws: any[] = [];
  try {
    const fetched = await client.fetch(LAWS_QUERY);
    laws = fetched && fetched.length > 0 ? fetched : STATIC_LAWS;
  } catch {
    laws = STATIC_LAWS;
  }
  return laws.map((law: any) => ({
    params: { slug: law.slug },
    props: { slug: law.slug },
  }));
}

const { slug } = Astro.params;
let law: any = null;

try {
  law = await client.fetch(LAW_BY_SLUG_QUERY, { slug });
} catch { /* fall through */ }

if (!law) {
  law = STATIC_LAWS.find((l: any) => l.slug === slug);
}

if (!law) return Astro.redirect('/tracker');

// Normalise slug (Sanity returns it as an object, static data as a string)
const lawSlug = typeof law.slug === 'object' ? law.slug.current : law.slug;

const allLaws = STATIC_LAWS;
const currentIndex = allLaws.findIndex((l: any) => l.slug === slug);
const prevLaw = currentIndex > 0 ? allLaws[currentIndex - 1] : null;
const nextLaw = currentIndex < allLaws.length - 1 ? allLaws[currentIndex + 1] : null;

function statusLabel(status: string) {
  if (status === 'in-force') return 'In force';
  if (status === 'pending') return 'Pending';
  return 'Proposed';
}

function tagClass(status: string) {
  if (status === 'in-force') return 'tag-force';
  if (status === 'pending') return 'tag-pending';
  return 'tag-proposed';
}

function formatDate(s: string) {
  if (!s) return '';
  try {
    return new Date(s + 'T12:00:00Z').toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric', timeZone: 'UTC' });
  } catch { return s; }
}

function formatMonth(s: string) {
  if (!s) return '';
  try {
    return new Date(s + 'T12:00:00Z').toLocaleDateString('en-GB', { month: 'long', year: 'numeric', timeZone: 'UTC' });
  } catch { return s; }
}

const ogDescription = law.scope || `${statusLabel(law.status)} HREDD legislation in ${law.jurisdiction}. Tracked monthly on hredd.org.`;
---

<BaseLayout
  title={`${law.name} — hredd.org`}
  description={ogDescription}
  ogType="article"
>

  <!-- BREADCRUMB -->
  <div class="breadcrumb page-margins">
    <a href="/tracker/">Tracker</a>
    <span>/</span>
    <span>{law.name}</span>
  </div>

  <!-- LAW HEADER -->
  <header class="law-header">
    <div class="eyebrow">{law.jurisdiction}</div>
    <h1 class="law-title serif">{law.name}</h1>
    {law.nativeName && <p class="law-native">{law.nativeName}</p>}
    <div class="law-header-meta">
      <span class={`tag ${tagClass(law.status)}`}>{statusLabel(law.status)}</span>
      {law.inForce && <span class="law-in-force">In force {formatMonth(law.inForce)}</span>}
    </div>
  </header>

  <!-- TWO-COLUMN LAYOUT -->
  <div class="law-body page-margins">

    <!-- MAIN COLUMN -->
    <main class="law-main">

      {law.scope && (
        <section class="law-section">
          <p class="section-label">Scope</p>
          <p class="scope-text serif">{law.scope}</p>
        </section>
      )}

      {law.provisions && law.provisions.length > 0 && (
        <section class="law-section">
          <p class="section-label">Key provisions</p>
          <ol class="provisions-list">
            {law.provisions.map((p: any, i: number) => (
              <li class="provision-item">
                <span class="provision-number mono">{String(i + 1).padStart(2, '0')}</span>
                <div class="provision-content">
                  {p.title && <p class="provision-title">{p.title}</p>}
                  {p.text && <p class="provision-text">{p.text}</p>}
                </div>
              </li>
            ))}
          </ol>
        </section>
      )}

      {law.timeline && law.timeline.length > 0 && (
        <section class="law-section">
          <p class="section-label">Timeline</p>
          <div class="timeline">
            {law.timeline.map((entry: any) => (
              <div class="timeline-entry">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                  <p class="timeline-date mono">{formatDate(entry.date)}</p>
                  <p class="timeline-event">{entry.event}</p>
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      {law.relatedLaws && law.relatedLaws.length > 0 && (
        <section class="law-section">
          <p class="section-label">Related legislation</p>
          <div class="related-laws-list">
            {law.relatedLaws.map((rel: any) => {
              const rSlug = typeof rel.slug === 'object' ? rel.slug.current : rel.slug;
              return (
                <a href={`/laws/${rSlug}`} class="related-law-link">
                  <span class="serif">{rel.name}</span>
                  <span class="related-law-juris">{rel.jurisdiction}</span>
                </a>
              );
            })}
          </div>
        </section>
      )}

    </main>

    <!-- SIDEBAR -->
    <aside class="law-sidebar">

      <section class="sidebar-section">
        <p class="section-label">Quick facts</p>
        <dl class="quick-facts">
          {law.jurisdiction && (
            <>
              <dt class="fact-label">Jurisdiction</dt>
              <dd class="fact-value serif">{law.jurisdiction}</dd>
            </>
          )}
          {law.status && (
            <>
              <dt class="fact-label">Status</dt>
              <dd class="fact-value serif">{statusLabel(law.status)}</dd>
            </>
          )}
          {law.year && (
            <>
              <dt class="fact-label">Enacted</dt>
              <dd class="fact-value serif">{law.year}</dd>
            </>
          )}
          {law.inForce && (
            <>
              <dt class="fact-label">In force since</dt>
              <dd class="fact-value serif">{formatMonth(law.inForce)}</dd>
            </>
          )}
        </dl>
      </section>

    </aside>
  </div>

  <!-- BOTTOM NAVIGATION -->
  <nav class="law-nav page-margins">
    <div class="law-nav-inner">
      {prevLaw ? (
        <a href={`/laws/${prevLaw.slug}`} class="law-nav-link law-nav-link--prev">
          <span class="law-nav-dir">Previous</span>
          <span class="law-nav-name serif">{prevLaw.name}</span>
        </a>
      ) : <span></span>}
      <a href="/tracker/" class="law-nav-back">Back to tracker</a>
      {nextLaw ? (
        <a href={`/laws/${nextLaw.slug}`} class="law-nav-link law-nav-link--next">
          <span class="law-nav-dir">Next</span>
          <span class="law-nav-name serif">{nextLaw.name}</span>
        </a>
      ) : <span></span>}
    </div>
  </nav>

</BaseLayout>

<style>
  .breadcrumb {
    font-family: var(--sans);
    font-size: 11px;
    color: var(--ink-3);
    display: flex;
    gap: 8px;
    align-items: center;
    padding-top: 20px;
    padding-bottom: 20px;
  }

  .breadcrumb a { color: var(--ink-3); }
  .breadcrumb a:hover { color: var(--accent); }

  /* LAW HEADER */
  .law-header {
    padding: 32px var(--pad-x) 40px;
    border-bottom: 1px solid var(--rule);
    max-width: 900px;
  }

  .law-header .eyebrow { margin-bottom: 16px; display: block; }

  .law-title {
    font-size: 52px;
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 12px;
  }

  .law-native {
    font-family: var(--serif);
    font-style: italic;
    font-size: 18px;
    color: var(--ink-3);
    margin: 0 0 20px;
  }

  .law-header-meta {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .law-in-force {
    font-family: var(--sans);
    font-size: 12px;
    color: var(--ink-3);
  }

  /* TWO-COLUMN BODY */
  .law-body {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: 0;
    padding-top: 0;
    padding-bottom: 0;
    align-items: start;
  }

  .law-main {
    padding-right: 48px;
    border-right: 1px solid var(--rule-soft);
  }

  .law-sidebar {
    position: sticky;
    top: 24px;
    max-height: calc(100vh - 48px);
    overflow-y: auto;
    padding-left: 40px;
    scrollbar-width: thin;
    scrollbar-color: var(--rule) transparent;
  }

  /* LAW SECTIONS */
  .law-section {
    padding: 40px 0;
    border-bottom: 1px solid var(--rule-soft);
  }

  .law-section:last-child { border-bottom: none; }

  .scope-text {
    font-size: 19px;
    line-height: 1.65;
    color: var(--ink-2);
  }

  /* Provisions */
  .provisions-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .provision-item {
    display: flex;
    gap: 20px;
    padding: 20px 0;
    border-bottom: 1px solid var(--rule-soft);
  }

  .provision-item:last-child { border-bottom: none; }

  .provision-number {
    font-size: 11px;
    color: var(--ink-3);
    flex-shrink: 0;
    min-width: 24px;
    padding-top: 3px;
  }

  .provision-content { flex: 1; }

  .provision-title {
    font-family: var(--sans);
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 6px;
    line-height: 1.4;
  }

  .provision-text {
    font-family: var(--sans);
    font-size: 13px;
    color: var(--ink-2);
    line-height: 1.6;
  }

  /* Timeline */
  .timeline {
    position: relative;
    padding-left: 24px;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 5px;
    top: 10px;
    bottom: 10px;
    width: 1px;
    background: var(--rule);
  }

  .timeline-entry {
    position: relative;
    padding-left: 24px;
    padding-bottom: 28px;
  }

  .timeline-entry:last-child { padding-bottom: 0; }

  .timeline-dot {
    position: absolute;
    left: -19px;
    top: 4px;
    width: 10px;
    height: 10px;
    background: var(--accent);
  }

  .timeline-date {
    font-size: 11px;
    color: var(--ink-3);
    margin-bottom: 4px;
  }

  .timeline-event {
    font-family: var(--sans);
    font-size: 14px;
    color: var(--ink);
    line-height: 1.5;
  }

  /* Related laws */
  .related-laws-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .related-law-link {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding: 14px 0;
    border-bottom: 1px solid var(--rule-soft);
    color: var(--ink);
    font-size: 16px;
  }

  .related-law-link:last-child { border-bottom: none; }
  .related-law-link:hover { color: var(--accent); }

  .related-law-juris {
    font-family: var(--sans);
    font-size: 11px;
    color: var(--ink-3);
    flex-shrink: 0;
  }

  /* SIDEBAR */
  .sidebar-section {
    padding: 40px 0;
    border-bottom: 1px solid var(--rule-soft);
  }

  .sidebar-section:first-child { padding-top: 40px; }
  .sidebar-section:last-child { border-bottom: none; padding-bottom: 40px; }

  .quick-facts {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin: 0;
  }

  .fact-label {
    font-family: var(--sans);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-3);
    margin-top: 14px;
    margin-bottom: 2px;
  }

  .fact-label:first-child { margin-top: 0; }

  .fact-value {
    font-size: 16px;
    color: var(--ink);
    line-height: 1.4;
    margin: 0;
  }

  /* BOTTOM NAV */
  .law-nav {
    padding: 32px 0;
    border-top: 1px solid var(--rule);
    margin-top: 0;
  }

  .law-nav-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 24px;
  }

  .law-nav-link {
    display: flex;
    flex-direction: column;
    gap: 4px;
    color: var(--ink);
  }

  .law-nav-link--next { text-align: right; margin-left: auto; }

  .law-nav-dir {
    font-family: var(--sans);
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-3);
  }

  .law-nav-name {
    font-size: 17px;
    color: var(--ink);
  }

  .law-nav-link:hover .law-nav-name { color: var(--accent); }

  .law-nav-back {
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-3);
    text-align: center;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 2px;
  }

  .law-nav-back:hover { color: var(--accent); border-color: var(--accent); }

  @media (max-width: 768px) {
    .law-title { font-size: 36px; }

    .law-body {
      grid-template-columns: 1fr;
    }

    .law-main {
      padding-right: 0;
      border-right: none;
    }

    .law-sidebar {
      position: static;
      max-height: none;
      padding-left: 0;
      border-top: 1px solid var(--rule);
      padding-top: 32px;
    }
  }
</style>
