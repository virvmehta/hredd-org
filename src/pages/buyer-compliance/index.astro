---
import BaseLayout from '../../layouts/Base.astro';
import { sanityClient } from '../../lib/sanity.js';
import { getAllLawRegionsQuery } from '../../lib/queries.js';
import { STATIC_LAWS } from '../../lib/staticData.js';

let laws: any[] = [];
try {
  const fetched = await sanityClient.fetch(getAllLawRegionsQuery);
  laws = fetched && fetched.length > 0 ? fetched : STATIC_LAWS;
} catch {
  laws = STATIC_LAWS;
}

// Build a serializable law map for client-side use
// Maps buyer country label to array of law objects with all fields needed for cards
const allLawsData = laws.map((l: any) => ({
  name: l.name,
  shortName: l.shortName || '',
  slug: l.slug?.current || l.slug,
  jurisdiction: l.jurisdiction || '',
  status: l.status || '',
  statusType: l.statusType || 'proposed',
  tableUpdateText: l.tableUpdateText || '',
}));
---

<BaseLayout
  title="Buyer Compliance Mapping — hredd.org"
  description="Suppliers: select your buyer countries to see which HREDD laws apply to your trade relationships."
  activePage="buyer-compliance"
>

  <!-- SECTION 1: HEADER + BUYER PILLS -->
  <section class="compliance-header snap-section">
    <div class="header-inner">
      <p class="page-eyebrow">Supplier tool</p>
      <h1 class="page-title">Buyer compliance mapping</h1>
      <p class="page-deck">Suppliers: select your buyer countries to see which HREDD laws apply to your trade relationships.</p>

      <div class="pills-block">
        <p class="pills-label">My buyers are in</p>
        <div class="filter-pills" id="filter-pills">
          {['Germany', 'France', 'Netherlands', 'Norway', 'United Kingdom', 'Switzerland', 'United States', 'Canada', 'Japan', 'Australia', 'South Korea', 'EU-wide'].map(country => (
            <button class="filter-pill" data-country={country}>{country}</button>
          ))}
        </div>
        <p class="pills-hint" id="pills-hint">Select one or more buyer countries above.</p>
      </div>
    </div>
  </section>

  <!-- SECTION 2: RESULTS -->
  <section class="results-section snap-section" id="results-section">
    <div class="results-inner">
      <div id="results-empty" class="results-empty">
        <p>Select buyer countries above to see applicable laws.</p>
      </div>
      <div id="results-list" class="results-list" hidden></div>
    </div>
  </section>

</BaseLayout>

<!-- Pass law data to client-side JS -->
<script define:vars={{ allLawsData }}>
  /* ======================================================
     BUYER TO LAW MAPPING
     Maps buyer country pill label to law slugs that apply
     ====================================================== */

  const pillToLawSlugs: Record<string, string[]> = {
    'Germany': ['german-supply-chain-act-lksg'],
    'France': ['french-duty-of-vigilance-law'],
    'Netherlands': ['dutch-child-labour-due-diligence-act'],
    'Norway': ['norwegian-transparency-act'],
    'United Kingdom': ['uk-modern-slavery-act'],
    'Switzerland': ['swiss-responsible-business-ordinance'],
    'United States': ['us-uflpa', 'california-sb-253-261'],
    'Canada': ['canada-flcca'],
    'Japan': ['japan-hrdd-guidelines'],
    'Australia': ['australia-modern-slavery-act'],
    'South Korea': ['south-korea-business-and-human-rights-act'],
    'EU-wide': [
      'eu-csddd',
      'eu-deforestation-regulation',
      'eu-forced-labour-regulation',
      'german-supply-chain-act-lksg',
      'french-duty-of-vigilance-law',
      'dutch-child-labour-due-diligence-act',
      'norwegian-transparency-act',
      'swiss-responsible-business-ordinance',
    ],
  };

  // Build a slug-indexed map from the law data
  const lawsBySlug = {};
  for (const law of allLawsData) {
    lawsBySlug[law.slug] = law;
  }

  const tagClass = { force: 'tag-force', pending: 'tag-pending', proposed: 'tag-proposed', delayed: 'tag-delayed' };

  function getTagClass(statusType) {
    return tagClass[statusType] || 'tag-proposed';
  }

  const pillsContainer = document.getElementById('filter-pills');
  const resultsEmpty = document.getElementById('results-empty');
  const resultsList = document.getElementById('results-list');
  const pinsHint = document.getElementById('pills-hint');
  const activePills = new Set();

  if (pillsContainer) {
    pillsContainer.querySelectorAll('.filter-pill').forEach(pill => {
      pill.addEventListener('click', () => {
        const country = pill.dataset.country || '';
        if (activePills.has(country)) {
          activePills.delete(country);
          pill.classList.remove('active');
        } else {
          activePills.add(country);
          pill.classList.add('active');
        }
        updateResults();
      });
    });
  }

  function updateResults() {
    if (!resultsEmpty || !resultsList) return;

    if (activePills.size === 0) {
      resultsEmpty.hidden = false;
      resultsList.hidden = true;
      resultsList.innerHTML = '';
      if (pinsHint) pinsHint.textContent = 'Select one or more buyer countries above.';
      return;
    }

    // Collect unique law slugs for all selected pills
    const slugSet = new Set();
    for (const pill of activePills) {
      for (const slug of (pillToLawSlugs[pill] || [])) {
        slugSet.add(slug);
      }
    }

    const laws = Array.from(slugSet)
      .map(slug => lawsBySlug[slug])
      .filter(Boolean);

    const count = laws.length;
    if (pinsHint) {
      const names = Array.from(activePills).join(', ');
      pinsHint.textContent = `Buyers in ${names}: ${count} ${count === 1 ? 'law applies' : 'laws apply'}.`;
    }

    if (count === 0) {
      resultsEmpty.hidden = false;
      resultsList.hidden = true;
      resultsList.innerHTML = '';
      return;
    }

    resultsEmpty.hidden = true;
    resultsList.hidden = false;

    resultsList.innerHTML = laws.map(law => `
      <div class="law-card">
        <div class="law-card-main">
          <p class="law-card-jurisdiction">${law.jurisdiction}</p>
          <a href="/tracker/${law.slug}" class="law-card-name">${law.name}</a>
          ${law.tableUpdateText ? `<p class="law-card-summary">${law.tableUpdateText}</p>` : ''}
        </div>
        <div class="law-card-meta">
          <span class="tag ${getTagClass(law.statusType)}">${law.status}</span>
          <a href="/tracker/${law.slug}" class="law-card-readmore">Read more &rarr;</a>
        </div>
      </div>
    `).join('');

    // Scroll to results after a short delay to let snap settle
    setTimeout(() => {
      const resultsSection = document.getElementById('results-section');
      if (resultsSection) resultsSection.scrollIntoView({ behavior: 'smooth' });
    }, 100);
  }
</script>

<style>
  /* ====================================================
     SCROLL SNAP
     ==================================================== */

  :global(html) {
    scroll-snap-type: y mandatory;
    scroll-behavior: smooth;
  }

  @media (max-width: 768px) {
    :global(html) {
      scroll-snap-type: y proximity;
    }
  }

  .snap-section {
    scroll-snap-align: start;
    scroll-snap-stop: always;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* ====================================================
     HEADER
     ==================================================== */

  .compliance-header {
    padding: 56px 56px 48px;
    border-bottom: 1px solid var(--text);
  }

  .header-inner {
    max-width: 760px;
  }

  .page-eyebrow {
    font-family: var(--font-sans);
    font-size: var(--text-10);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
    margin-bottom: 20px;
  }

  .page-title {
    font-family: var(--font-serif);
    font-size: var(--text-56);
    font-weight: 400;
    line-height: 1.0;
    letter-spacing: -0.02em;
    margin-bottom: 20px;
  }

  .page-deck {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-19);
    color: var(--text-mid);
    max-width: 560px;
    line-height: 1.5;
    margin-bottom: 40px;
  }

  /* ====================================================
     PILLS
     ==================================================== */

  .pills-block {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .pills-label {
    font-family: var(--font-sans);
    font-size: var(--text-10);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--text-muted);
  }

  .filter-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .filter-pill {
    font-family: var(--font-sans);
    font-size: var(--text-13);
    padding: 8px 16px;
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--text-mid);
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }

  .filter-pill:hover {
    border-color: var(--accent);
    color: var(--text);
  }

  .filter-pill.active {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--inverse-text);
  }

  .pills-hint {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-14);
    color: var(--text-muted);
  }

  /* ====================================================
     RESULTS
     ==================================================== */

  .results-section {
    padding: 56px 56px;
    border-bottom: 1px solid var(--text);
    justify-content: flex-start;
  }

  .results-inner {
    max-width: 760px;
  }

  .results-empty {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-17);
    color: var(--text-muted);
    padding: 48px 0;
  }

  .results-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Law card */
  :global(.law-card) {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
    padding: 24px 0;
    border-bottom: 1px solid var(--rule-light);
  }

  :global(.law-card:last-child) {
    border-bottom: none;
  }

  :global(.law-card-main) {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  :global(.law-card-jurisdiction) {
    font-family: var(--font-sans);
    font-size: var(--text-10);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
  }

  :global(.law-card-name) {
    font-family: var(--font-serif);
    font-size: var(--text-20);
    color: var(--text);
    line-height: 1.2;
    transition: color 0.15s;
  }

  :global(.law-card-name:hover) {
    color: var(--accent);
  }

  :global(.law-card-summary) {
    font-family: var(--font-sans);
    font-size: var(--text-13);
    color: var(--text-mid);
    line-height: 1.5;
  }

  :global(.law-card-meta) {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
    flex-shrink: 0;
  }

  :global(.law-card-readmore) {
    font-family: var(--font-sans);
    font-size: var(--text-12);
    color: var(--accent);
    white-space: nowrap;
    transition: opacity 0.15s;
  }

  :global(.law-card-readmore:hover) {
    opacity: 0.7;
  }

  /* ====================================================
     MOBILE
     ==================================================== */

  @media (max-width: 768px) {
    .snap-section {
      min-height: unset;
      scroll-snap-align: none;
    }

    .compliance-header,
    .results-section {
      padding: 40px 20px;
    }

    .page-title {
      font-size: var(--text-38);
    }
  }
</style>
