        <!-- Ireland (not clickable, context only) -->
        <polygon class="land" points="432,100 445,97 447,110 440,115 432,110"/>

        <!-- Norway (mainland, simplified) -->
        <polygon
          class="country has-laws"
          data-country="norway"
          points="490,52 538,47 565,52 560,80 540,95 510,92 490,82"
        />

        <!-- Netherlands (small) -->
        <polygon
          class="country has-laws"
          data-country="netherlands"
          points="490,103 503,101 505,111 490,111"
        />

        <!-- Germany -->
        <polygon
          class="country has-laws"
          data-country="germany"
          points="498,100 522,98 527,108 522,122 510,125 498,118"
        />

        <!-- France (including Corsica omitted for simplicity) -->
        <polygon
          class="country has-laws"
          data-country="france"
          points="458,110 500,108 504,122 493,133 472,134 458,122"
        />

        <!-- Switzerland (tiny) -->
        <polygon
          class="country has-laws"
          data-country="switzerland"
          points="498,118 512,117 513,125 498,125"
        />

        <!-- India (simplified peninsular shape) -->
        <polygon
          class="country has-laws"
          data-country="india"
          points="660,152 737,152 742,185 735,228 715,240 692,235 668,218 660,185"
        />

        <!-- Japan (main islands, simplified) -->
        <polygon
          class="country has-laws"
          data-country="japan"
          points="828,128 862,125 868,150 852,168 828,160"
        />

        <!-- South Korea (small) -->
        <polygon
          class="country has-laws"
          data-country="korea"
          points="816,147 828,145 828,160 816,158"
        />

        <!-- Australia -->
        <polygon
          class="country has-laws"
          data-country="australia"
          points="780,280 892,278 895,368 850,390 795,375 778,338"
        />

        <!-- Tasmania -->
        <polygon class="land" points="830,395 845,390 848,405 835,408"/>
      </svg>
    </div>

    <!-- MAP LEGEND -->
    <div class="map-legend">
      <div class="legend-item">
        <span class="legend-swatch legend-swatch--laws"></span>
        <span>Has HREDD legislation</span>
      </div>
      <div class="legend-item">
        <span class="legend-swatch legend-swatch--none"></span>
        <span>No tracked legislation</span>
      </div>
      <div class="legend-item">
        <span class="legend-swatch legend-swatch--selected"></span>
        <span>Selected</span>
      </div>
    </div>

    <!-- COUNTRY DETAIL PANEL -->
    <div class="country-panel" id="country-panel">
      <p class="country-panel-default">Select a highlighted country to view its HREDD legislation.</p>
    </div>
  </section>

  <!-- SUPPLIER FILTER SECTION -->
  <section class="supplier-filter">
    <div class="filter-intro">
      <h2 class="filter-title">What applies to your buyers</h2>
      <p class="filter-deck">Select the countries you export to. We will show you which HREDD laws your buyers are subject to.</p>
    </div>
    <p class="filter-label">My buyers are in</p>
    <div class="filter-pills" id="filter-pills">
      {['Germany', 'France', 'Netherlands', 'Norway', 'United Kingdom', 'Switzerland', 'United States', 'Canada', 'Japan', 'Australia', 'South Korea', 'EU-wide'].map(country => (
        <button class="filter-pill" data-country={country}>{country}</button>
      ))}
    </div>
    <div class="filter-summary" id="filter-summary">
      <p class="filter-summary-text" id="filter-summary-text">Select one or more buyer countries above to see what applies.</p>
    </div>
  </section>

  <!-- FULL TABLE SECTION -->
  <section class="full-table-section page-margins">
    <div class="table-controls">
      <div class="filter-tabs" id="status-tabs">
        <button class="filter-tab active" data-status="all">All</button>
        <button class="filter-tab" data-status="force">In force</button>
        <button class="filter-tab" data-status="pending">Pending</button>
        <button class="filter-tab" data-status="proposed">Proposed</button>
      </div>
      <span class="row-count" id="row-count">Showing {laws.length} of {laws.length}</span>
    </div>

    <table class="tracker-table" id="full-tracker-table">
      <colgroup>
        <col class="col-law" />
        <col class="col-status" />
        <col />
        <col class="col-date" />
      </colgroup>
      <thead>
        <tr>
          <th>Law</th>
          <th>Status</th>
          <th>Latest movement</th>
          <th>Updated</th>
        </tr>
      </thead>
      <tbody>
        {lawsByRegion.map(group => (
          <>
            <tr class="region-header-row" data-region-row>
              <td colspan="4" class="region-label">{group.region}</td>
            </tr>
            {group.laws.map((law: any) => (
              <tr data-status-type={law.statusType || 'proposed'} data-row>
                <td>
                  <a href={`/tracker/${law.slug?.current || law.slug}`} class="law-name">{law.shortName || law.name}</a>
                  <p class="law-jurisdiction">{law.jurisdiction}</p>
                </td>
                <td>
                  <span class={`tag ${getStatusTag(law)}`}>{law.status}</span>
                </td>
                <td>
                  <p class="law-update">{law.tableUpdateText}</p>
                </td>
                <td>
                  <p class="law-date">{formatDate(law.lastUpdated)}</p>
                </td>
              </tr>
            ))}
          </>
        ))}
      </tbody>
    </table>
  </section>

</BaseLayout>

<style>
  /* ====================================================
     PAGE HEADER
     ==================================================== */

  .page-header {
    text-align: center;
    padding: 56px;
    border-bottom: 1px solid var(--text);
  }

  .page-eyebrow {
    font-family: var(--font-sans);
    font-size: var(--text-10);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
    margin-bottom: 20px;
  }

  .page-title {
    font-family: var(--font-serif);
    font-size: var(--text-72);
    font-weight: 400;
    line-height: 1.0;
    letter-spacing: -0.02em;
    margin-bottom: 20px;
  }

  .page-deck {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-19);
    color: var(--text-mid);
    margin-bottom: 20px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .page-meta {
    font-family: var(--font-sans);
    font-size: var(--text-12);
    color: var(--text-muted);
    display: flex;
    justify-content: center;
    gap: 8px;
    align-items: center;
  }

  .meta-dot {
    color: var(--rule);
  }

  /* ====================================================
     MOVEMENTS
     ==================================================== */

  .movements-section {
    padding-top: 48px;
    padding-bottom: 48px;
    border-bottom: 1px solid var(--text);
  }

  .movements-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 32px;
  }

  .movement-card {
    padding-left: 16px;
    border-left: 2px solid var(--accent);
  }

  .movement-law {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: var(--text-19);
    line-height: 1.25;
    margin-bottom: 6px;
    color: var(--text);
  }

  .movement-jurisdiction {
    font-family: var(--font-sans);
    font-size: var(--text-11);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    margin-bottom: 12px;
  }

  .movement-summary {
    font-family: var(--font-sans);
    font-size: var(--text-14);
    line-height: 1.6;
    color: var(--text-mid);
  }

  /* ====================================================
     MAP
     ==================================================== */

  .map-section {
    padding-top: 48px;
    padding-bottom: 48px;
    border-bottom: 1px solid var(--text);
  }

  .map-instruction {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-14);
    color: var(--text-muted);
    text-align: center;
    margin-bottom: 24px;
  }

  .map-container {
    background: var(--surface);
    padding: 24px;
    border: 1px solid var(--rule);
    overflow: hidden;
  }

  #world-map {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Land and country base styles */
  .land {
    fill: #C9C0AE;
    stroke: #EEE9DD;
    stroke-width: 0.5;
  }

  .country {
    stroke: #EEE9DD;
    stroke-width: 0.5;
    cursor: default;
    transition: fill 0.15s;
  }

  .country.has-laws {
    fill: #4A3F32;
    cursor: pointer;
  }

  .country.has-laws:hover {
    fill: #B8460E;
  }

  .country.selected {
    fill: #B8460E;
  }

  /* MAP LEGEND */
  .map-legend {
    display: flex;
    justify-content: center;
    gap: 24px;
    margin-top: 16px;
    font-family: var(--font-sans);
    font-size: var(--text-12);
    color: var(--text-muted);
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .legend-swatch {
    display: inline-block;
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  .legend-swatch--laws     { background: #4A3F32; }
  .legend-swatch--none     { background: #C9C0AE; }
  .legend-swatch--selected { background: #B8460E; }

  /* COUNTRY DETAIL PANEL */
  .country-panel {
    border: 1px solid var(--rule);
    padding: 24px;
    background: var(--bg);
    margin-top: 24px;
  }

  .country-panel-default {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-14);
    color: var(--text-muted);
    text-align: center;
  }

  .panel-country-name {
    font-family: var(--font-serif);
    font-size: var(--text-24);
    font-weight: 500;
    margin-bottom: 16px;
    color: var(--text);
  }

  .panel-law-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .panel-law-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid var(--rule-light);
  }

  .panel-law-item:last-child {
    border-bottom: none;
  }

  .panel-law-name {
    font-family: var(--font-serif);
    font-size: var(--text-16);
    color: var(--text);
    flex: 1;
  }

  /* ====================================================
     SUPPLIER FILTER
     ==================================================== */

  .supplier-filter {
    background: var(--inverse-bg);
    padding: 32px 56px;
    border-bottom: 1px solid var(--rule);
  }

  .filter-intro {
    margin-bottom: 24px;
  }

  .filter-title {
    font-family: var(--font-serif);
    font-size: var(--text-28);
    font-weight: 400;
    color: var(--inverse-text);
    margin-bottom: 10px;
  }

  .filter-deck {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-16);
    color: #C9C0AE;
    line-height: 1.5;
    max-width: 580px;
  }

  .filter-label {
    font-family: var(--font-sans);
    font-size: var(--text-10);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--accent);
    margin-bottom: 14px;
  }

  .filter-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 20px;
  }

  .filter-pill {
    font-family: var(--font-sans);
    font-size: var(--text-12);
    padding: 8px 16px;
    background: transparent;
    border: 1px solid #6B5D4F;
    color: #C9C0AE;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }

  .filter-pill:hover {
    border-color: var(--accent);
    color: var(--inverse-text);
  }

  .filter-pill.active {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--inverse-text);
  }

  .filter-summary {
    border-top: 1px solid #4A3F32;
    padding-top: 20px;
  }

  .filter-summary-text {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-15);
    color: #8B7E6E;
    line-height: 1.5;
  }

  /* ====================================================
     FULL TABLE
     ==================================================== */

  .full-table-section {
    padding-top: 48px;
    padding-bottom: 48px;
  }

  .table-controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
  }

  .row-count {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-13);
    color: var(--text-muted);
  }

  .region-header-row td {
    padding: 28px 0 8px;
    border-bottom: none;
  }

  .col-law    { width: 32%; }
  .col-status { width: 18%; }
  .col-date   { width: 18%; }

  .region-label {
    font-family: var(--font-sans);
    font-size: var(--text-10);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
  }
</style>

<script>
  /* ======================================================
     LAWS BY COUNTRY DATA (mirrors brief specification)
     ====================================================== */

  const lawsByCountry: Record<string, Array<{name: string; status: string; tag: string; slug: string}>> = {
    germany: [{name: 'German Supply Chain Act (LkSG)', status: 'In force', tag: 'tag-force', slug: 'german-supply-chain-act-lksg'}],
    france: [{name: 'French Duty of Vigilance Law', status: 'In force', tag: 'tag-force', slug: 'french-duty-of-vigilance-law'}],
    netherlands: [{name: 'Dutch Child Labour Due Diligence Act', status: 'In force', tag: 'tag-force', slug: 'dutch-child-labour-due-diligence-act'}],
    norway: [{name: 'Norwegian Transparency Act', status: 'In force', tag: 'tag-force', slug: 'norwegian-transparency-act'}],
    uk: [{name: 'UK Modern Slavery Act', status: 'Updates pending', tag: 'tag-pending', slug: 'uk-modern-slavery-act'}],
    switzerland: [{name: 'Swiss Responsible Business Ordinance', status: 'Under review', tag: 'tag-proposed', slug: 'swiss-responsible-business-ordinance'}],
    usa: [
      {name: 'US UFLPA', status: 'In force', tag: 'tag-force', slug: 'us-uflpa'},
      {name: 'California SB 253 / SB 261', status: 'Implementing', tag: 'tag-pending', slug: 'california-sb-253-261'},
    ],
    canada: [{name: 'Canada FLCCA', status: 'In force', tag: 'tag-force', slug: 'canada-flcca'}],
    brazil: [{name: 'Brazil Supply Chain Due Diligence Bill', status: 'In Congress', tag: 'tag-pending', slug: 'brazil-supply-chain-due-diligence-bill'}],
    india: [{name: 'India BRSR Core', status: 'Expanding', tag: 'tag-pending', slug: 'india-brsr-core'}],
    japan: [{name: 'Japan HRDD Guidelines', status: 'Voluntary', tag: 'tag-proposed', slug: 'japan-hrdd-guidelines'}],
    korea: [{name: 'South Korea Business and Human Rights Act', status: 'In committee', tag: 'tag-proposed', slug: 'south-korea-business-and-human-rights-act'}],
    australia: [{name: 'Australia Modern Slavery Act', status: 'Reform proposed', tag: 'tag-pending', slug: 'australia-modern-slavery-act'}],
  };

  const countryNames: Record<string, string> = {
    germany: 'Germany', france: 'France', netherlands: 'Netherlands', norway: 'Norway',
    uk: 'United Kingdom', switzerland: 'Switzerland', usa: 'United States', canada: 'Canada',
    brazil: 'Brazil', india: 'India', japan: 'Japan', korea: 'South Korea', australia: 'Australia',
  };

  /* ======================================================
     MAP INTERACTION
     ====================================================== */

  const mapEl = document.getElementById('world-map');
  const panelEl = document.getElementById('country-panel');
  let selectedCountry: string | null = null;

  if (mapEl && panelEl) {
    mapEl.querySelectorAll<SVGElement>('.country.has-laws').forEach(el => {
      el.addEventListener('click', () => {
        const country = el.dataset.country || '';

        // Deselect previous
        mapEl.querySelectorAll('.country.selected').forEach(c => c.classList.remove('selected'));

        if (selectedCountry === country) {
          // Toggle off
          selectedCountry = null;
          panelEl.innerHTML = '<p class="country-panel-default">Select a highlighted country to view its HREDD legislation.</p>';
        } else {
          selectedCountry = country;
          el.classList.add('selected');
          renderPanel(country);
        }
      });
    });
  }

  function renderPanel(country: string) {
    if (!panelEl) return;
    const laws = lawsByCountry[country] || [];
    const name = countryNames[country] || country;

    const lawsHtml = laws.map(law =>
      `<div class="panel-law-item">
        <a href="/tracker/${law.slug}" class="panel-law-name">${law.name}</a>
        <span class="tag ${law.tag}">${law.status}</span>
      </div>`
    ).join('');

    panelEl.innerHTML = `
      <p class="panel-country-name">${name}</p>
      <div class="panel-law-list">${lawsHtml}</div>
    `;
  }

  /* ======================================================
     SUPPLIER FILTER PILLS
     ====================================================== */

  const pillCountryMap: Record<string, string[]> = {
    'Germany': ['germany'],
    'France': ['france'],
    'Netherlands': ['netherlands'],
    'Norway': ['norway'],
    'United Kingdom': ['uk'],
    'Switzerland': ['switzerland'],
    'United States': ['usa'],
    'Canada': ['canada'],
    'Japan': ['japan'],
    'Australia': ['australia'],
    'South Korea': ['korea'],
    'EU-wide': ['germany', 'france', 'netherlands', 'norway', 'switzerland'],
  };

  const pillsContainer = document.getElementById('filter-pills');
  const summaryText = document.getElementById('filter-summary-text');
  const activePills = new Set<string>();

  if (pillsContainer && summaryText) {
    pillsContainer.querySelectorAll<HTMLButtonElement>('.filter-pill').forEach(pill => {
      pill.addEventListener('click', () => {
        const country = pill.dataset.country || '';
        if (activePills.has(country)) {
          activePills.delete(country);
          pill.classList.remove('active');
        } else {
          activePills.add(country);
          pill.classList.add('active');
        }
        updateFilterSummary();
      });
    });
  }

  function updateFilterSummary() {
    if (!summaryText) return;
    if (activePills.size === 0) {
      summaryText.innerHTML = 'Select one or more buyer countries above to see what applies.';
      summaryText.style.color = '#8B7E6E';
      summaryText.style.fontStyle = 'italic';
      return;
    }

    const countryCodes = new Set<string>();
    activePills.forEach(pill => {
      (pillCountryMap[pill] || []).forEach(code => countryCodes.add(code));
    });

    const lawSet = new Set<string>();
    countryCodes.forEach(code => {
      (lawsByCountry[code] || []).forEach(law => lawSet.add(law.name));
    });

    const names = Array.from(activePills).join(', ');
    const count = lawSet.size;

    summaryText.style.fontStyle = 'normal';
    summaryText.style.color = '#C9C0AE';
    summaryText.innerHTML = `Your buyers in <strong style="color:#EEE9DD;font-family:var(--font-sans);font-weight:500">${names}</strong> are subject to <strong style="color:#EEE9DD;font-family:var(--font-sans);font-weight:500">${count}</strong> HREDD ${count === 1 ? 'law' : 'laws'}. Scroll to the table below to see them.`;
  }

  /* ======================================================
     STATUS FILTER TABS
     ====================================================== */

  const statusTabs = document.getElementById('status-tabs');
  const tableEl = document.getElementById('full-tracker-table');
  const rowCountEl = document.getElementById('row-count');

  if (statusTabs && tableEl) {
    const totalRows = tableEl.querySelectorAll('[data-row]').length;

    statusTabs.querySelectorAll<HTMLButtonElement>('.filter-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        statusTabs.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');

        const status = tab.dataset.status || 'all';
        let visible = 0;

        tableEl.querySelectorAll<HTMLElement>('[data-row]').forEach(row => {
          const rowStatus = row.dataset.statusType || '';
          let show = false;

          if (status === 'all') {
            show = true;
          } else if (status === 'force') {
            show = rowStatus === 'force';
          } else if (status === 'pending') {
            show = rowStatus === 'pending';
          } else if (status === 'proposed') {
            show = rowStatus === 'proposed' || rowStatus === 'delayed';
          }

          row.style.display = show ? '' : 'none';
          if (show) visible++;
        });

        // Show/hide region headers based on visible rows
        tableEl.querySelectorAll<HTMLElement>('[data-region-row]').forEach(regionRow => {
          // Check if next sibling rows are visible
          let next = regionRow.nextElementSibling as HTMLElement;
          let hasVisible = false;
          while (next && !next.dataset.regionRow) {
            if (next.dataset.row && next.style.display !== 'none') {
              hasVisible = true;
              break;
            }
            next = next.nextElementSibling as HTMLElement;
          }
          regionRow.style.display = hasVisible ? '' : 'none';
        });

        if (rowCountEl) {
          rowCountEl.textContent = `Showing ${visible} of ${totalRows}`;
        }
      });
    });
  }
</script>
