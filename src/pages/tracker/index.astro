        <ellipse class="land" cx="850" cy="320" rx="20" ry="8"/>
        <ellipse class="land" cx="855" cy="280" rx="12" ry="6"/>

        <!-- New Zealand (simplified) -->
        <polygon class="land" points="900,415 910,408 920,420 912,432 900,428"/>
        <polygon class="land" points="905,440 915,435 918,448 908,452"/>

        <!-- Sri Lanka -->
        <ellipse class="land" cx="690" cy="250" rx="6" ry="9"/>

        <!-- Madagascar -->
        <polygon class="land" points="570,338 582,328 590,358 582,385 570,378"/>

        <!-- ======================================
             INTERACTIVE COUNTRIES WITH HREDD LAWS
             ====================================== -->

        <!-- Canada -->
        <polygon
          class="country has-laws"
          data-country="canada"
          points="108,60 195,22 265,22 315,42 315,88 295,95 295,150 255,150 235,165 205,168 165,155 140,155 110,105"
        />

        <!-- USA (continental) -->
        <polygon
          class="country has-laws"
          data-country="usa"
          points="148,150 295,150 308,162 312,182 295,198 255,198 215,192 170,198 152,185 148,165"
        />

        <!-- Brazil -->
        <polygon
          class="country has-laws"
          data-country="brazil"
          points="278,238 388,255 394,298 388,350 365,398 330,445 292,458 257,430 237,393 228,335 218,282 255,252"
        />

        <!-- UK (Great Britain, simplified) -->
        <polygon
          class="country has-laws"
          data-country="uk"
          points="448,90 472,87 477,100 472,117 458,118 447,108"
