        <polygon class="land" points="338,22 395,15 432,22 436,50 418,65 388,70 358,58 338,44"/>

        <!-- North America (background, includes Mexico/Central America not covered by specific countries) -->
        <polygon class="land" points="32,58 108,30 195,22 265,22 315,40 335,80 315,90 315,150 295,150 245,168 205,175 165,155 140,155 115,105 88,93"/>

        <!-- Caribbean / small islands (simplified dot) -->
        <circle class="land" cx="290" cy="248" r="4"/>
        <circle class="land" cx="305" cy="250" r="3"/>

        <!-- South America -->
        <polygon class="land" points="205,250 278,238 328,238 388,253 396,298 390,350 368,400 332,448 293,460 258,432 238,393 228,335 218,282"/>

        <!-- Iceland -->
        <polygon class="land" points="396,75 420,70 432,80 420,90 400,88"/>

        <!-- Europe (background land mass) -->
        <polygon class="land" points="430,82 460,78 465,90 472,80 490,52 538,47 565,52 560,80 542,95 548,108 582,108 588,142 578,178 542,198 510,200 488,190 460,204 435,188 435,150 453,140 455,115 440,107"/>

        <!-- Iberian Peninsula extension -->
        <polygon class="land" points="430,155 458,148 460,170 445,180 430,172"/>

        <!-- Italy boot (simplified) -->
        <polygon class="land" points="490,148 510,145 515,172 505,195 495,190 488,165"/>

        <!-- Africa -->
        <polygon class="land" points="435,202 465,197 508,197 570,208 588,235 600,295 578,375 558,448 498,480 445,445 428,383 425,312 430,252"/>

        <!-- Arabian Peninsula -->
        <polygon class="land" points="572,218 620,210 638,232 628,268 608,280 588,265 572,245"/>

        <!-- Russia / Northern Asia -->
        <polygon class="land" points="515,30 722,28 888,25 950,42 950,145 900,162 862,158 828,125 792,122 768,140 745,158 715,170 688,163 660,180 638,158 618,148 600,158 578,152 558,122 515,100"/>

        <!-- Central and South Asia -->
        <polygon class="land" points="558,152 620,148 660,182 692,180 748,172 770,200 803,238 818,270 795,298 758,300 748,278 725,285 700,275 675,295 642,275 618,252 595,275 578,248 558,205"/>

        <!-- Southeast Asia (Indochina/Malaysia simplified) -->
