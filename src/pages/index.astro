---
import BaseLayout from '../layouts/Base.astro';
import { sanityClient } from '../lib/sanity.js';
import { getAllArticlesQuery, getAllLawSlugsQuery } from '../lib/queries.js';
import { STATIC_ARTICLES, STATIC_LAWS } from '../lib/staticData.js';

let articles: any[] = [];
let laws: any[] = [];

try {
  const [fetchedArticles, fetchedLaws] = await Promise.all([
    sanityClient.fetch(getAllArticlesQuery),
    sanityClient.fetch(getAllLawSlugsQuery),
  ]);
  articles = fetchedArticles && fetchedArticles.length > 0 ? fetchedArticles : STATIC_ARTICLES;
  laws = fetchedLaws && fetchedLaws.length > 0 ? fetchedLaws : STATIC_LAWS;
} catch {
  articles = STATIC_ARTICLES;
  laws = STATIC_LAWS;
}

const previewLaws = laws.slice(0, 5);
const previewArticles = articles.slice(0, 4);

// "This month" block counts
const now = new Date();
const buildMonth = now.getMonth();
const buildYear = now.getFullYear();

const lawsTracked = laws.length;

const newMovements = laws.filter((l: any) => {
  if (!l.lastUpdated) return false;
  const d = new Date(l.lastUpdated);
  return d.getMonth() === buildMonth && d.getFullYear() === buildYear;
}).length;

const newPieces = articles.filter((a: any) => {
  if (!a.publishedAt) return false;
  const d = new Date(a.publishedAt);
  return d.getMonth() === buildMonth && d.getFullYear() === buildYear;
}).length;

// "Latest" section: most recent publish month and count
const MONTH_NAMES = [
  'January', 'February', 'March', 'April', 'May', 'June',
  'July', 'August', 'September', 'October', 'November', 'December',
];

let latestMonthLabel = '';
let latestMonthCount = 0;

const sortedArticles = [...articles].sort((a: any, b: any) =>
  new Date(b.publishedAt || 0).getTime() - new Date(a.publishedAt || 0).getTime()
);

if (sortedArticles.length > 0 && sortedArticles[0].publishedAt) {
  const d = new Date(sortedArticles[0].publishedAt);
  const latestM = d.getMonth();
  const latestY = d.getFullYear();
  latestMonthLabel = `${MONTH_NAMES[latestM]} ${latestY}`;
  latestMonthCount = articles.filter((a: any) => {
    if (!a.publishedAt) return false;
    const ad = new Date(a.publishedAt);
    return ad.getMonth() === latestM && ad.getFullYear() === latestY;
  }).length;
}

const latestSubtitle = latestMonthLabel
  ? `${latestMonthLabel} · ${latestMonthCount} ${latestMonthCount === 1 ? 'piece' : 'pieces'}`
  : '';

function getStatusTag(law: any) {
  return `tag-${law.statusType || 'proposed'}`;
}

function formatDate(dateStr: string) {
  if (!dateStr) return '';
  try {
    return new Date(dateStr).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
  } catch {
    return dateStr;
  }
}
---

<BaseLayout
  title="hredd.org"
  description="Tracking global HREDD legislation and its implications for those most affected and least consulted."
  activePage="home"
>

  <!-- SECTION 1: MASTHEAD + THIS MONTH BLOCK -->
  <section class="masthead snap-section">
    <div class="masthead-inner">
      <div class="masthead-content">
        <p class="masthead-eyebrow">Established 2026 &middot; Independent &middot; Monthly</p>
        <h1 class="masthead-title">
          Human rights<br />
          <em>&amp; environmental</em><br />
          due diligence
        </h1>
        <p class="masthead-deck">Tracking global HREDD legislation and its implications for those most affected and least consulted.</p>
      </div>

      <aside class="this-month-block">
        <p class="this-month-label">This month</p>
        <ul class="this-month-stats">
          <li class="this-month-stat">
            <span class="stat-number">{lawsTracked}</span>
            <span class="stat-label">laws tracked</span>
          </li>
          <li class="this-month-stat">
            <span class="stat-number">{newMovements}</span>
            <span class="stat-label">new movements</span>
          </li>
          <li class="this-month-stat">
            <span class="stat-number">{newPieces}</span>
            <span class="stat-label">new pieces</span>
          </li>
        </ul>
        <a href="/articles" class="this-month-cta">&rarr; Read the issue</a>
      </aside>
    </div>
  </section>

  <!-- SECTION 2: LATEST ARTICLES -->
  <section class="articles-section snap-section">
    <div class="section-header">
      <h2 class="section-header-title">Latest</h2>
      {latestSubtitle && <span class="section-header-meta">{latestSubtitle}</span>}
    </div>
    <div class="articles-grid">
      {previewArticles.map((article: any, i: number) => (
        <article class={`article-card${i >= previewArticles.length - 2 ? ' article-card--no-bottom' : ''}`}>
          <p class="card-category">{article.category}</p>
          <h3 class="card-title">
            <a href={`/articles/${article.slug?.current || article.slug}`}>{article.title}</a>
          </h3>
          {(article.excerpt || article.deck) && (
            <p class="card-excerpt">{article.excerpt || article.deck}</p>
          )}
          <p class="card-byline">{article.authorName} &middot; {article.readTime} min read</p>
        </article>
      ))}
    </div>
    <div class="articles-cta">
      <a href="/articles" class="cta-link">View all articles</a>
    </div>
  </section>

  <!-- SECTION 3: TRACKER PREVIEW -->
  <section class="tracker-preview snap-section">
    <div class="section-header">
      <h2 class="section-header-title">The tracker</h2>
      <span class="section-header-meta">
        {laws.length} laws &middot; Updated {MONTH_NAMES[buildMonth]} {buildYear}
      </span>
    </div>
    <table class="tracker-table">
      <colgroup>
        <col class="col-law" />
        <col class="col-status" />
        <col />
        <col class="col-date" />
      </colgroup>
      <thead>
        <tr>
          <th>Law</th>
          <th>Status</th>
          <th>Latest movement</th>
          <th>Updated</th>
        </tr>
      </thead>
      <tbody>
        {previewLaws.map((law: any) => (
          <tr>
            <td>
              <a href={`/tracker/${law.slug?.current || law.slug}`} class="law-name">{law.shortName || law.name}</a>
              <p class="law-jurisdiction">{law.jurisdiction}</p>
            </td>
            <td>
              <span class={`tag ${getStatusTag(law)}`}>{law.status}</span>
            </td>
            <td>
              <p class="law-update">{law.tableUpdateText}</p>
            </td>
            <td>
              <p class="law-date">{formatDate(law.lastUpdated)}</p>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
    <div class="tracker-cta">
      <a href="/tracker" class="cta-link">View all {laws.length} laws</a>
    </div>
  </section>

  <!-- SECTION 4: NEWSLETTER -->
  <section class="newsletter-section snap-section" id="subscribe">
    <p class="newsletter-eyebrow">The Monthly Brief</p>
    <h2 class="newsletter-title">What moved this month, <em>and what it means</em></h2>
    <p class="newsletter-deck">One email, the first Monday of every month. Tracker updates, new analysis, and the developments that matter most for Global South actors.</p>
    <form class="newsletter-form" action="https://buttondown.email/hredd" method="post" target="_blank">
      <input type="email" name="email" placeholder="your@email.com" class="newsletter-input" required />
      <button type="submit" class="newsletter-button">Subscribe</button>
    </form>
  </section>

</BaseLayout>

<style>
  /* ====================================================
     SCROLL SNAP
     ==================================================== */

  :global(html) {
    scroll-snap-type: y mandatory;
    scroll-behavior: smooth;
  }

  @media (max-width: 768px) {
    :global(html) {
      scroll-snap-type: y proximity;
    }
  }

  .snap-section {
    scroll-snap-align: start;
    scroll-snap-stop: always;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* ====================================================
     MASTHEAD
     ==================================================== */

  .masthead {
    border-bottom: 1px solid var(--text);
    padding: 56px 56px;
  }

  .masthead-inner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 48px;
  }

  .masthead-content {
    flex: 1;
  }

  .masthead-eyebrow {
    font-family: var(--font-sans);
    font-size: var(--text-10);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
    margin-bottom: 28px;
  }

  .masthead-title {
    font-family: var(--font-serif);
    font-size: var(--text-72);
    font-weight: 400;
    line-height: 0.97;
    letter-spacing: -0.02em;
    margin-bottom: 28px;
  }

  .masthead-deck {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-20);
    color: var(--text-mid);
    max-width: 560px;
    line-height: 1.5;
  }

  /* "This month" block */
  .this-month-block {
    flex-shrink: 0;
    width: 200px;
    border: 1px solid var(--rule);
    background: var(--surface);
    padding: 20px 20px 16px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-self: flex-start;
    margin-top: 8px;
  }

  .this-month-label {
    font-family: var(--font-sans);
    font-size: var(--text-10);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
  }

  .this-month-stats {
    display: flex;
    flex-direction: column;
    gap: 10px;
    list-style: none;
  }

  .this-month-stat {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }

  .stat-number {
    font-family: var(--font-serif);
    font-size: var(--text-22);
    font-weight: 500;
    color: var(--text);
    line-height: 1;
  }

  .stat-label {
    font-family: var(--font-sans);
    font-size: var(--text-12);
    color: var(--text-mid);
  }

  .this-month-cta {
    font-family: var(--font-sans);
    font-size: var(--text-12);
    font-weight: 500;
    color: var(--accent);
    border-top: 1px solid var(--rule-light);
    padding-top: 12px;
    transition: opacity 0.15s;
  }

  .this-month-cta:hover {
    opacity: 0.7;
  }

  /* ====================================================
     ARTICLES SECTION
     ==================================================== */

  .articles-section {
    padding: 0 56px;
    border-bottom: 1px solid var(--text);
    justify-content: flex-start;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 40px 0 24px;
    border-bottom: 1px solid var(--rule);
  }

  .section-header-title {
    font-family: var(--font-serif);
    font-size: var(--text-32);
    font-weight: 400;
  }

  .section-header-meta {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-13);
    color: var(--text-muted);
  }

  .articles-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .article-card {
    padding: 32px 28px;
    border-bottom: 1px solid var(--rule);
  }

  .article-card:nth-child(odd) {
    border-right: 1px solid var(--rule);
    padding-left: 0;
  }

  .article-card:nth-child(even) {
    padding-right: 0;
  }

  .article-card--no-bottom {
    border-bottom: none;
  }

  .card-category {
    font-family: var(--font-sans);
    font-size: var(--text-10);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--accent);
    margin-bottom: 12px;
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: var(--text-24);
    font-weight: 400;
    line-height: 1.18;
    letter-spacing: -0.005em;
    margin-bottom: 10px;
  }

  .card-title a {
    color: var(--text);
  }

  .card-title a:hover {
    color: var(--accent);
  }

  .card-excerpt {
    font-family: var(--font-sans);
    font-size: var(--text-13);
    line-height: 1.6;
    color: #4A3F32;
    margin-bottom: 14px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-byline {
    font-family: var(--font-sans);
    font-size: var(--text-11);
    color: var(--text-muted);
    padding-top: 12px;
    border-top: 1px solid var(--rule-light);
  }

  .articles-cta {
    text-align: center;
    padding: 24px 0 40px;
  }

  .cta-link {
    font-family: var(--font-sans);
    font-size: var(--text-12);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text);
    border-bottom: 1px solid var(--text);
    padding-bottom: 2px;
    transition: color 0.15s, border-color 0.15s;
  }

  .cta-link:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* ====================================================
     TRACKER PREVIEW
     ==================================================== */

  .tracker-preview {
    padding: 0 56px;
    border-bottom: 1px solid var(--text);
    justify-content: flex-start;
  }

  .col-law    { width: 32%; }
  .col-status { width: 18%; }
  .col-date   { width: 18%; }

  .tracker-cta {
    text-align: center;
    padding: 24px 0 40px;
  }

  /* ====================================================
     NEWSLETTER
     ==================================================== */

  .newsletter-section {
    padding: 56px 56px;
    text-align: center;
    border-bottom: 1px solid var(--text);
  }

  .newsletter-eyebrow {
    font-family: var(--font-sans);
    font-size: var(--text-10);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .newsletter-title {
    font-family: var(--font-serif);
    font-size: var(--text-38);
    font-weight: 400;
    line-height: 1.15;
    margin-bottom: 20px;
  }

  .newsletter-deck {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-17);
    color: var(--text-mid);
    max-width: 480px;
    margin: 0 auto 32px;
    line-height: 1.5;
  }

  .newsletter-form {
    display: flex;
    max-width: 460px;
    margin: 0 auto;
  }

  .newsletter-input {
    flex: 1;
    padding: 12px 16px;
    background: transparent;
    border: 1px solid var(--text);
    border-right: none;
    color: var(--text);
    font-family: var(--font-sans);
    font-size: var(--text-14);
  }

  .newsletter-input::placeholder {
    color: #8B7E6E;
  }

  .newsletter-button {
    padding: 12px 24px;
    background: var(--text);
    color: var(--inverse-text);
    font-family: var(--font-sans);
    font-size: var(--text-11);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    border: 1px solid var(--text);
    cursor: pointer;
    transition: background 0.15s;
  }

  .newsletter-button:hover {
    background: var(--accent);
    border-color: var(--accent);
  }

  /* ====================================================
     MOBILE
     ==================================================== */

  @media (max-width: 768px) {
    .masthead {
      padding: 40px 20px;
    }

    .masthead-inner {
      flex-direction: column;
      gap: 32px;
    }

    .masthead-title {
      font-size: var(--text-48);
    }

    .this-month-block {
      width: 100%;
    }

    .articles-section,
    .tracker-preview {
      padding: 0 20px;
    }

    .newsletter-section {
      padding: 56px 20px;
    }

    .snap-section {
      min-height: unset;
      scroll-snap-align: none;
    }
  }
</style>
