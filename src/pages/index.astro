---
import BaseLayout from '../layouts/Base.astro';
import { client } from '../lib/sanity.js';
import { ARTICLES_QUERY, LAWS_QUERY } from '../lib/queries.js';
import { STATIC_ARTICLES, STATIC_LAWS } from '../lib/staticData.js';

let articles: any[] = [];
let laws: any[] = [];

try {
  const [fa, fl] = await Promise.all([
    client.fetch(ARTICLES_QUERY),
    client.fetch(LAWS_QUERY),
  ]);
  articles = fa && fa.length > 0 ? fa : STATIC_ARTICLES;
  laws = fl && fl.length > 0 ? fl : STATIC_LAWS;
} catch {
  articles = STATIC_ARTICLES;
  laws = STATIC_LAWS;
}

const leadArticle = articles[0];
const secondaryArticles = articles.slice(1, 4);
const lowerArticles = articles.slice(4, 7);

const previewLaws = laws.slice(0, 5);

const inForceCount = laws.filter((l: any) => l.status === 'in-force').length;
const pendingCount = laws.filter((l: any) => l.status === 'pending').length;
const jurisdictionCount = new Set(laws.map((l: any) => l.jurisdiction).filter(Boolean)).size;

function formatDate(s: string) {
  if (!s) return '';
  try { return new Date(s + 'T12:00:00Z').toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric', timeZone: 'UTC' }); }
  catch { return s; }
}

function statusLabel(status: string) {
  if (status === 'in-force') return 'In force';
  if (status === 'pending') return 'Pending';
  if (status === 'proposed') return 'Proposed';
  return status;
}

function tagClass(status: string) {
  if (status === 'in-force') return 'tag-force';
  if (status === 'pending') return 'tag-pending';
  return 'tag-proposed';
}
---

<BaseLayout
  title="hredd.org"
  description="Independent coverage of human-rights and environmental due-diligence legislation, written from a Global South perspective."
>

<div class="page">

  <!-- Masthead -->
  <section class="masthead">
    <div class="masthead-left">
      <div class="eyebrow">Established 2026 · Independent · Fortnightly</div>
      <h1 class="masthead-h1">Human rights<br /><em>&amp; environmental</em><br />due diligence.</h1>
      <p class="masthead-deck">Tracking HREDD legislation and its implications for those most affected and least consulted.</p>
    </div>
    <div class="v"></div>
    <aside class="masthead-stats">
      <div class="stat-label eyebrow">As of April 2026</div>
      <div class="stat-row">
        <div class="stat-n mono">{laws.length}</div>
        <div class="stat-k">Statutes tracked</div>
      </div>
      <div class="stat-row">
        <div class="stat-n mono">{inForceCount}</div>
        <div class="stat-k">In force</div>
      </div>
      <div class="stat-row">
        <div class="stat-n mono">{jurisdictionCount}</div>
        <div class="stat-k">Jurisdictions</div>
      </div>
      <a class="stat-cta" href="/tracker/">View the tracker →</a>
    </aside>
  </section>

  <div class="rule-full"></div>

  <!-- Latest -->
  <section class="latest">
    <div class="latest-left">
      <div class="section-eyebrow eyebrow">Latest</div>
      {leadArticle && (
        <article class="lead-article">
          <div class="eyebrow">{leadArticle.category}</div>
          <h2 class="lead-title serif">
            <a href={`/articles/${leadArticle.slug}`}>{leadArticle.title}</a>
          </h2>
          {leadArticle.deck && <p class="lead-deck">{leadArticle.deck}</p>}
          <div class="byline">
            <span class="author">{leadArticle.author}</span>
            <span class="sep">·</span>
            <span>{formatDate(leadArticle.publishedAt)}</span>
            <span class="sep">·</span>
            <span>{leadArticle.readTime} min</span>
          </div>
        </article>
      )}
      <div class="secondary-list">
        {secondaryArticles.map((a: any) => (
          <article class="secondary-article">
            <div class="eyebrow">{a.category}</div>
            <h3 class="secondary-title serif">
              <a href={`/articles/${a.slug}`}>{a.title}</a>
            </h3>
            <div class="byline">
              <span class="author">{a.author}</span>
              <span class="sep">·</span>
              <span>{a.readTime} min</span>
            </div>
          </article>
        ))}
      </div>
    </div>
    <div class="v"></div>
    <aside class="latest-right">
      <div class="lower-list">
        {lowerArticles.map((a: any) => (
          <article class="lower-article">
            <div class="eyebrow">{a.category}</div>
            <h3 class="lower-title serif">
              <a href={`/articles/${a.slug}`}>{a.title}</a>
            </h3>
            <div class="byline">
              <span class="author">{a.author}</span>
              <span class="sep">·</span>
              <span>{a.readTime} min</span>
            </div>
          </article>
        ))}
      </div>
      <a class="all-articles-link" href="/articles/">All articles →</a>
    </aside>
  </section>

  <div class="rule-full"></div>

  <!-- Tracker teaser -->
  <section class="tracker-teaser">
    <div class="teaser-left">
      <div class="eyebrow">The Tracker</div>
      <p class="teaser-lede serif"><em>A working ledger of HREDD statutes on the books.</em> {inForceCount} in force, {pendingCount} pending transposition.</p>
      <table class="tracker-table">
        <thead>
          <tr>
            <th></th>
            <th>Statute</th>
            <th>Jurisdiction</th>
            <th style="text-align:right">Status</th>
          </tr>
        </thead>
        <tbody>
          {previewLaws.map((l: any, i: number) => (
            <tr>
              <td class="num mono">{String(i + 1).padStart(2, '0')}</td>
              <td class="name serif">
                <a href={`/laws/${l.slug}`} class="law-name">{l.name}</a>
              </td>
              <td class="juris">{l.jurisdiction}</td>
              <td class="status-cell"><span class={`status ${l.status}`}>{statusLabel(l.status)}</span></td>
            </tr>
          ))}
        </tbody>
      </table>
      <a class="teaser-cta" href="/tracker/">Full ledger ({laws.length} statutes) →</a>
    </div>
    <div class="v"></div>
    <aside class="teaser-right">
      <div class="aside-label eyebrow">A note on scope</div>
      <p>hredd.org tracks legislation that creates substantive obligations on companies to conduct due diligence across their supply chains on human rights and environmental grounds.</p>
      <p>We do not track voluntary frameworks, disclosure-only regimes without enforcement, or sector-specific commodity standards unless they carry mandatory due diligence requirements.</p>
      <p>The tracker is updated monthly. <a href="/about/#methodology">Read our methodology →</a></p>
    </aside>
  </section>

  <div class="rule-full"></div>

  <!-- Subscribe band -->
  <section class="subscribe-band">
    <div class="subscribe-text">
      <div class="eyebrow">The fortnightly letter · Free · No advertising</div>
      <h2 class="serif subscribe-h2">Read the letter, <em>every other Friday</em>.</h2>
    </div>
    <form class="subscribe-form" action="https://buttondown.email/hredd" method="post" target="_blank">
      <input type="email" name="email" placeholder="your.name@domain.org" required />
      <button type="submit">Subscribe →</button>
    </form>
  </section>

</div>

</BaseLayout>

<style>
.rule-full { border-top: 1px solid var(--rule); }

/* Masthead */
.masthead {
  display: grid;
  grid-template-columns: 1.45fr 1px 1fr;
  gap: 0;
  padding: 64px 0 56px;
  align-items: start;
}
.masthead-left { padding-right: 56px; }
.masthead-h1 {
  font-family: var(--serif);
  font-size: 88px;
  font-weight: 400;
  line-height: 0.96;
  letter-spacing: -0.02em;
  margin: 20px 0 28px;
}
.masthead-deck {
  font-family: var(--serif);
  font-style: italic;
  font-size: 20px;
  color: var(--ink-2);
  max-width: 480px;
  line-height: 1.5;
}
.masthead-stats { padding-left: 56px; }
.stat-label { margin-bottom: 24px; display: block; }
.stat-row { display: flex; align-items: baseline; gap: 12px; padding: 14px 0; border-bottom: 1px solid var(--rule-soft); }
.stat-row:last-of-type { border-bottom: none; }
.stat-n { font-size: 32px; color: var(--ink); }
.stat-k { font-family: var(--sans); font-size: 13px; color: var(--ink-3); }
.stat-cta { display: inline-block; margin-top: 20px; font-family: var(--sans); font-size: 12px; font-weight: 500; letter-spacing: 0.04em; color: var(--accent); }
.v { width: 1px; background: var(--rule); align-self: stretch; }

/* Latest */
.latest {
  display: grid;
  grid-template-columns: 1.55fr 1px 1fr;
  padding: 56px 0;
  align-items: start;
}
.latest-left { padding-right: 56px; }
.section-eyebrow { margin-bottom: 28px; display: block; }
.lead-article { padding-bottom: 32px; border-bottom: 1px solid var(--rule-soft); margin-bottom: 32px; }
.lead-title {
  font-family: var(--serif);
  font-size: 42px;
  font-weight: 400;
  line-height: 1.06;
  letter-spacing: -0.01em;
  margin: 10px 0 14px;
}
.lead-title a { color: var(--ink); }
.lead-title a:hover { color: var(--accent); }
.lead-deck { font-family: var(--sans); font-size: 14px; color: var(--ink-2); line-height: 1.6; margin-bottom: 16px; }
.secondary-list { display: flex; flex-direction: column; gap: 24px; }
.secondary-article { padding-bottom: 24px; border-bottom: 1px solid var(--rule-soft); }
.secondary-article:last-child { border-bottom: none; padding-bottom: 0; }
.secondary-title { font-family: var(--serif); font-size: 22px; font-weight: 400; line-height: 1.2; margin: 8px 0 10px; }
.secondary-title a { color: var(--ink); }
.secondary-title a:hover { color: var(--accent); }
.latest-right { padding-left: 56px; }
.lower-list { display: flex; flex-direction: column; gap: 0; }
.lower-article { padding: 18px 0; border-bottom: 1px solid var(--rule-soft); }
.lower-article:last-child { border-bottom: none; }
.lower-title { font-family: var(--serif); font-size: 18px; font-weight: 400; line-height: 1.25; margin: 6px 0 8px; }
.lower-title a { color: var(--ink); }
.lower-title a:hover { color: var(--accent); }
.all-articles-link { display: inline-block; margin-top: 24px; font-family: var(--sans); font-size: 12px; font-weight: 500; letter-spacing: 0.04em; color: var(--accent); }

/* Tracker teaser */
.tracker-teaser {
  display: grid;
  grid-template-columns: 1.3fr 1px 1fr;
  padding: 56px 0;
  align-items: start;
}
.teaser-left { padding-right: 56px; }
.teaser-lede { font-size: 19px; color: var(--ink-2); margin: 12px 0 32px; line-height: 1.5; }
.teaser-lede em { color: var(--accent); font-style: italic; }
.num { font-size: 11px; color: var(--ink-3); padding-right: 16px; }
.name { font-size: 15px; }
.juris { font-family: var(--sans); font-size: 12px; color: var(--ink-3); }
.status-cell { text-align: right; }
.teaser-cta { display: inline-block; margin-top: 20px; font-family: var(--sans); font-size: 12px; font-weight: 500; letter-spacing: 0.04em; color: var(--accent); }
.teaser-right { padding-left: 56px; }
.aside-label { margin-bottom: 20px; display: block; }
.teaser-right p { font-family: var(--sans); font-size: 13px; color: var(--ink-2); line-height: 1.65; margin-bottom: 16px; }
.teaser-right p:last-child { margin-bottom: 0; }
.teaser-right a { color: var(--accent); }

/* Subscribe */
.subscribe-band {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 48px 0;
  gap: 48px;
}
.subscribe-h2 { font-family: var(--serif); font-size: 32px; font-weight: 400; margin: 12px 0 0; line-height: 1.15; }
.subscribe-h2 em { color: var(--accent); font-style: italic; }
.subscribe-form { display: flex; flex-shrink: 0; }
.subscribe-form input {
  padding: 12px 16px;
  background: transparent;
  border: 1px solid var(--ink);
  border-right: none;
  color: var(--ink);
  font-family: var(--sans);
  font-size: 14px;
  min-width: 260px;
}
.subscribe-form input::placeholder { color: var(--ink-3); }
.subscribe-form button {
  padding: 12px 24px;
  background: var(--ink);
  color: var(--bg);
  font-family: var(--sans);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border: 1px solid var(--ink);
  cursor: pointer;
  white-space: nowrap;
}
.subscribe-form button:hover { background: var(--accent); border-color: var(--accent); }

@media (max-width: 900px) {
  .masthead, .latest, .tracker-teaser { grid-template-columns: 1fr; gap: 32px; }
  .v { display: none; }
  .masthead-left, .latest-left, .teaser-left { padding-right: 0; }
  .masthead-stats, .latest-right, .teaser-right { padding-left: 0; }
  .masthead-h1 { font-size: 56px; }
  .subscribe-band { flex-direction: column; align-items: flex-start; }
  .subscribe-form input { min-width: 200px; }
}
</style>
